# SSL Configuration
SSL_KEYSTORE_PATH=/app/certs/fintech.p12
SSL_KEYSTORE_PASSWORD=Shekhar@123
SSL_KEYSTORE_TYPE=PKCS12
SSL_KEY_ALIAS=gateway-ssl

# PostgreSQL Configuration (CRITICAL - MUST BE PRESENT)
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=fintech_password

# PostgreSQL Base Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fintechdb
DB_USER=fintech_user
DB_PASS=fintech_password

# Database URLs for services (Updated for Patroni)
MAIN_DB_URL=jdbc:postgresql://patroni-main-master:5432/fintech_main
SHARD1_DB_URL=jdbc:postgresql://patroni-shard-1-master:5432/fintech_shard1
SHARD2_DB_URL=jdbc:postgresql://patroni-shard-2-master:5432/fintech_shard2
SHARD3_DB_URL=jdbc:postgresql://patroni-shard-3-master:5432/fintech_shard3

# Read Replica URLs (Updated for Patroni)
MAIN_REPLICA_DB_URL=jdbc:postgresql://patroni-main-replica:5432/fintech_main
SHARD1_REPLICA_DB_URL=jdbc:postgresql://patroni-shard-1-replica:5432/fintech_shard1
SHARD2_REPLICA_DB_URL=jdbc:postgresql://patroni-shard-2-replica:5432/fintech_shard2
SHARD3_REPLICA_DB_URL=jdbc:postgresql://patroni-shard-3-replica:5432/fintech_shard3

# Specialized Database URLs
AUTH_DB_URL=jdbc:postgresql://fintech_postgres_auth:5432/fintech_auth
SCHEDULER_DB_URL=jdbc:postgresql://fintech_postgres_scheduler:5432/fintech_scheduler
RETRY_DB_URL=jdbc:postgresql://fintech_postgres_retry:5432/fintech_retry

# ShardingSphere Proxy
SHARDINGSPHERE_PROXY_HOST=fintech_shardingsphere_proxy
SHARDINGSPHERE_PROXY_PORT=3307
SHARDINGSPHERE_PROXY_URL=jdbc:postgresql://fintech_shardingsphere_proxy:3307/fintech_db

# Redis Configuration
REDIS_HOST=fintech_redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://fintech_redis:6379


# Kafka Configuration
KAFKA_HOST=kafka
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_MANAGEMENT_PORT=15672

# Jaeger Configuration
JAEGER_HOST=jaeger
JAEGER_PORT=14268
JAEGER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces

# Splunk Configuration
SPLUNK_HOST=splunk
SPLUNK_PORT=8088
SPLUNK_TOKEN=fintech-hec-token-2024
SPLUNK_HEC_TOKEN=fintech-hec-token-2024
SPLUNK_WEB_PORT=8000
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=splunkpassword123

# Service Ports
GATEWAY_SERVICE_PORT=8080
AUTH_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
AUTHORIZATION_SERVICE_PORT=8085
TRANSACTION_SERVICE_PORT=8086
REPORTING_SERVICE_PORT=8088
USER_SERVICE_PORT=8089
SCHEDULER_SERVICE_PORT=8090
RETRY_SERVICE_PORT=8091

# JWT Configuration
JWT_KEYSTORE_PATH=/app/certs/jwt-keystore.p12
JWT_KEYSTORE_PASSWORD=Shekhar@123
JWT_KEY_ALIAS=jwt-key
JWT_PUBLIC_CERT_PATH=/app/certs/jwt-public.crt

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=admin

# Patroni Configuration
POSTGRES_REPLICATION_PASSWORD=replicator_password
PATRONI_ADMIN_PASSWORD=admin_password

# ETCD Configuration
ETCD_IMAGE_VERSION=v3.5.9
PATRONI_IMAGE_VERSION=3.3.2

# PostgreSQL Version
POSTGRES_VERSION=15

# Container Image Versions
PROMETHEUS_VERSION=v2.45.0
GRAFANA_VERSION=10.4.2
JAEGER_VERSION=1.52
SPLUNK_VERSION=9.1.2
ZOOKEEPER_VERSION=7.5.0
KAFKA_VERSION=7.5.0
REDIS_VERSION=7-alpine
RABBITMQ_VERSION=3-management

# Network Configuration
FINTECH_NETWORK_SUBNET=172.20.0.0/16

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=30s

# PostgreSQL Health Check Configuration
PG_HEALTH_CHECK_INTERVAL=10s
PG_HEALTH_CHECK_TIMEOUT=5s
PG_HEALTH_CHECK_RETRIES=5
PG_HEALTH_CHECK_START_PERIOD=30s
